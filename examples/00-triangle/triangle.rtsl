struct Point {
	vec2 position;
	vec3 color;
};

struct Vertex {
	vec4 position;
	vec3 color;
};

@stage : vertex
fn vertex_entry(Point point) -> Vertex : position(clip), color(smooth) {
	return Vertex(vec4(point.position, 0.0, 1.0), point.color);
}

@stage : fragment
fn fragment_entry(Vertex vertex) -> vec4 {
	return vec4(vertex.color, 1.0);
}
